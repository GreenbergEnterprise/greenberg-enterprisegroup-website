# Copy this file to .env.local and fill in your real values.
# .env.local is already git-ignored — never commit real credentials.

# MongoDB Atlas connection string (from Atlas: Database > Connect > Drivers).
# Include the username/password and, if you're not setting MONGODB_DB below,
# a database name after the host, e.g. "...mongodb.net/greenberg?retryWrites=...".
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"

# Optional: database name, if you'd rather not put it in the URI above.
MONGODB_DB="greenberg"
