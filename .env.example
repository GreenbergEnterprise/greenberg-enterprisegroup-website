# Copy this file to .env.local and fill in your real values.
# .env.local is already git-ignored — never commit real credentials.

# MongoDB Atlas connection string (from Atlas: Database > Connect > Drivers).
# Include the username/password and, if you're not setting MONGODB_DB below,
# a database name after the host, e.g. "...mongodb.net/greenberg?retryWrites=...".
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"

# Optional: database name, if you'd rather not put it in the URI above.
MONGODB_DB="greenberg"

# Contact form — self-hosted CAPTCHA
# A long random string used to encrypt/sign CAPTCHA challenges. Not tied to
# any external account; generate one yourself, e.g.: openssl rand -hex 32
CAPTCHA_SECRET="replace-with-a-long-random-string"

# Contact form — email via Resend (https://resend.com)
# API key from Resend's dashboard (Settings > API Keys).
RESEND_API_KEY="re_your_api_key"

# The "from" address used to send confirmation/notification emails. Resend's
# shared sandbox sender (shown below) only delivers to your own Resend
# account email — verify a sending domain in Resend and use an address on it
# (e.g. "Greenberg Enterprise Group <hello@greenbergenterprisegroup.com>")
# before this can email real visitors.
CONTACT_FROM_EMAIL="Greenberg Enterprise Group <onboarding@resend.dev>"

# Optional: where the "someone submitted the contact form" notification goes.
# Defaults to the contact email already set in lib/content.ts.
CONTACT_TO_EMAIL="hello@greenbergenterprisegroup.com"
